---
const { title, description, type = 'WebPage' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://charli.info').href;
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const licenseUrl = 'https://creativecommons.org/licenses/by-sa/4.0/';
const documentTitle = title;

const schemaOrg = type === 'WebSite'
  ? {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://charli.info/#website",
          "url": "https://charli.info/",
          "name": "Charli.info",
          "description": description,
          "author": { "@id": "https://charli.info/#person" },
          "license": licenseUrl
        },
        {
          "@type": "Person",
          "@id": "https://charli.info/#person",
          "name": "Charli-Jo Tyrer",
          "url": "https://charli.info/",
          "sameAs": ["https://github.com/CharliVerse"]
        }
      ]
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": canonicalUrl,
      "url": canonicalUrl,
      "name": documentTitle,
      "description": description,
      "license": licenseUrl,
      "isPartOf": { "@id": "https://charli.info/#website" },
      "author": { "@id": "https://charli.info/#person" }
    };
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="license" href={licenseUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
    <title>{documentTitle}</title>

    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={type === 'WebSite' ? 'website' : 'article'} />
    <meta property="og:site_name" content="Charli.info" />
    <meta name="dcterms.license" content={licenseUrl} />
    <meta name="zic-version" content="1.5" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>

    <header>
      <p>Charli.info</p>
      <nav aria-label="Main navigation">
        <ul>
          <li><a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Home</a></li>
          <li><a href="/blind-ant/" aria-current={currentPath === '/blind-ant' ? 'page' : undefined}>Blind Ant</a></li>
          <li><a href="/carrados/" aria-current={currentPath === '/carrados' ? 'page' : undefined}>Carrados</a></li>
        </ul>
      </nav>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer aria-label="Site footer">
      <p>Charli-Jo Tyrer - <a href="https://github.com/CharliVerse">CharliVerse on GitHub</a></p>
      <p>Content licence: <a rel="license" href={licenseUrl}>CC BY-SA 4.0</a></p>
    </footer>
  </body>
</html>

---
import Base from '../../../../layouts/Base.astro';

const hashtags = [
  '#BlindButBrave', '#OvercomingObstacles', '#InspirationalTech', '#AccessibilityForSome',
  '#DisabilityDoesntStopUs', '#WeSeeYouToo', '#HeartwarmingTech', '#TechForGoodish',
  '#DigitalInclusionish', '#EmpowermentButMakeItProfitable', '#AllyshipAsAService',
  '#SocialImpactish', '#InspirationEconomy', '#EmotionallyDrivenROI',
  '#TechThatCaresAsLongAsItConverts', '#BlindButBankable', '#FeelGoodFunding',
  '#SightUnseenButSponsorable', '#DisabilityDollars', '#NotAllBlindPeople',
  '#AbleismWithASmile', '#PayToEmpower', '#StartupVisionary', '#PathosDrivenPerformance',
  '#InclusivityMattersIfItGoesViral', '#CharliKnowsBest', '#TheyllNeverSeeYouComing™',
];
---

<Base
  title="Big Charli’s Blind Marketing Consultancy™ | Blind Marketing Consultancy | Blind Ant"
  description="A fictional promotional course that satirises exploitative marketing aimed at blind people."
  type="Article"
>
  <article aria-labelledby="bmc-title">
    <h1 id="bmc-title">Big Charli’s Blind Marketing Consultancy™</h1>
    <p class="site-intro">“They’ll never see you coming.”™</p>

    <figure>
      <img
        src="/images/big-charli-blind-marketing-promo.png"
        width="1024"
        height="1536"
        alt="Big Charli, a white woman with long red hair, stands in a black trouser suit, white shirt and black heels beside a tall white banner. The banner bears the dark-blue words ‘Big Charli’s Blind Marketing Consultancy’ and the slogan ‘They’ll never see you coming.’"
        loading="eager"
        decoding="async"
      />
      <figcaption>Big Charli promoting the consultancy.</figcaption>
    </figure>

    <figure>
      <img
        src="/images/big-charli-blind-marketing-graphic.png"
        width="1024"
        height="1536"
        alt="Cream promotional poster for Big Charli’s Blind Marketing Consultancy. Large black lettering is framed by blue icons of an eye, sunglasses, a megaphone, a target and a stylised person. The headline says, ‘They’ll never see you coming.’ The course content and testimonials are transcribed below."
        loading="lazy"
        decoding="async"
      />
      <figcaption>The course promotional poster.</figcaption>
    </figure>

    <p>Want to sell overpriced tech to blind people but don’t want to waste time on accessibility, ethics, or actual usefulness?</p>
    <p>Big Charli’s got your back, baby. For just £10K a day, I’ll teach you how to turn empathy into ROI, one emotionally manipulative hashtag at a time.</p>

    <section aria-labelledby="what-you-learn">
      <h2 id="what-you-learn">What You’ll Learn</h2>

      <section aria-labelledby="optics-over-outcomes">
        <h3 id="optics-over-outcomes">Optics over Outcomes</h3>
        <p>Why looking inclusive is way easier (and cheaper) than being inclusive.</p>
      </section>

      <section aria-labelledby="hashtag-alchemy">
        <h3 id="hashtag-alchemy">Hashtag Alchemy</h3>
        <p>Transform meaningless gestures into inspirational campaigns. Try classics like:</p>
        <p>#BlindButBrave #HeroesWithCanes #WeSeeYouToo #InclusivityMattersIfItGoesViral</p>
      </section>

      <section aria-labelledby="granny-to-grift">
        <h3 id="granny-to-grift">Granny-to-Grift Pipeline™</h3>
        <p>Perfect your pitch for lonely pensioners and their carers. Free talking points:</p>
        <blockquote><p>“Your mum deserves independence… for just £4,999/month!”</p></blockquote>
      </section>

      <section aria-labelledby="targeted-ads">
        <h3 id="targeted-ads">Targeted Ads, Blurred Ethics</h3>
        <p>Master the art of emotionally manipulative Facebook ads, complete with royalty-free piano music and staged tearful testimonials.</p>
      </section>
    </section>

    <section aria-labelledby="testimonials">
      <h2 id="testimonials">Real (fake) Testimonials</h2>
      <blockquote><p>“I never knew marketing could be this morally grey AND wildly profitable. Big Charli changed my life—and my bank balance.”</p></blockquote>
      <p>— Chad Startup, Founder of EmpathiTech™</p>
      <blockquote><p>“Before Big Charli, our product was ethical and broke. Now it’s exploitative and scaling fast.”</p></blockquote>
      <p>— Tanya Brandwash, Head of Marketing, Pathos AI</p>
      <blockquote><p>“Wait… this is satire, right?”</p></blockquote>
      <p>— Confused Intern</p>
    </section>

    <section aria-labelledby="bonus-pack">
      <h2 id="bonus-pack">Bonus Pack</h2>
      <p>Sign up today and get our exclusive e-book: <em>From Altruism to Algorithm: The 7-Figure Playbook for Pretending to Care</em>.</p>
      <p>Apply now at <span aria-label="Big Charli Sees You Coming dot biz">www.BigCharliSeesYouComing.biz</span>. (Site not screen reader compatible – duh.)</p>
    </section>

    <section aria-labelledby="hashtag-dump">
      <h2 id="hashtag-dump">Hashtag Dump</h2>
      <p>{hashtags.join(' ')}</p>
    </section>
  </article>

  <nav aria-label="Blind Marketing Consultancy sequence">
    <ul><li><a href="/pieces/blind-marketing-consultancy/">Return to Blind Marketing Consultancy</a></li></ul>
  </nav>
</Base>

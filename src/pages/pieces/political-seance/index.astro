---
import Base from '../../../layouts/Base.astro';

const objects = [
  {
    title: 'Grievance Grifter™',
    href: '/pieces/political-seance/grievance-grifter/',
    description: 'The complete Reaction-in-a-Box movement starter kit.',
  },
  {
    title: 'The Hard Centre Manifesto',
    href: '/pieces/political-seance/the-hard-centre-manifesto/',
    description: 'A declaration of evidence, fairness and responsibility in the real world.',
  },
  {
    title: 'The Hard Centre: Recruitment Manual',
    href: '/pieces/political-seance/hard-centre-recruitment-manual/',
    description: 'A craft manual for organisers and posters.',
  },
];
---

<Base
  title="Political Seance | Blind Ant | Charli-Jo Tyrer"
  description="Political Seance is a Blind Ant design-fiction Piece examining the products, pitches and performance of manufactured grievance."
  type="Article"
>
  <h1>Political Seance</h1>

  <p class="site-intro">
    A design-fiction Piece about the products, pitches and performance of manufactured grievance.
  </p>

  <section aria-labelledby="political-seance-objects">
    <h2 id="political-seance-objects">Objects in Political Seance</h2>
    <ol>
      {objects.map((object) => (
        <li>
          <p><a href={object.href}>{object.title}</a></p>
          <p>{object.description}</p>
        </li>
      ))}
    </ol>
  </section>

  <p>Political Seance is a sequenced Piece. Begin with <a href="/pieces/political-seance/grievance-grifter/">Grievance Grifter™</a>.</p>
</Base>
